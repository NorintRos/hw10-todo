<h1>Todo List</h1>

<!-- Create -->
<form class="add-form" action="/todos" method="POST">
  <input type="text" name="text" placeholder="What needs to be done?" required />
  <button type="submit">Add</button>
</form>

<!-- List -->
{{#if todos.length}}
  {{#each todos}}
  <div class="todo-item">

    <!-- Toggle complete -->
    <form class="toggle-form" action="/todos/{{this.id}}/complete" method="POST">
      <input type="hidden" name="completed"
        value="{{#if this.completed}}false{{else}}true{{/if}}" />
      <button type="submit" class="toggle-btn {{#if this.completed}}is-completed{{/if}}">{{#if this.completed}}&#9679;{{else}}&#9675;{{/if}}</button>
    </form>

    <span class="todo-text {{#if this.completed}}completed{{/if}}">{{this.text}}</span>

    <!-- Action buttons -->
    <button type="button" class="edit-toggle">Edit</button>

    <!-- Delete -->
    <form class="delete-form" action="/todos/{{this.id}}/delete" method="POST">
      <button type="submit" class="delete-btn">Delete</button>
    </form>

    <!-- Edit text (visible without JS, hidden with JS until toggled) -->
    <form class="edit-form" action="/todos/{{this.id}}/edit" method="POST">
      <input type="text" name="text" value="{{this.text}}" />
      <button type="submit">Save</button>
    </form>

  </div>
  {{/each}}
{{else}}
  <p class="empty-state">No todos yet. Add one above.</p>
{{/if}}
