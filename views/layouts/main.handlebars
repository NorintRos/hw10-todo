<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Todo App</title>
  <style>
    body             { font-family: sans-serif; max-width: 700px; margin: 40px auto; padding: 0 16px; }
    .page-header     { display: flex; align-items: center; justify-content: space-between; gap: 16px; margin-bottom: 24px; }
    .session-meta    { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .session-meta p  { margin: 0; color: #444; }
    h1               { margin-bottom: 24px; }
    .add-form        { display: flex; gap: 8px; margin-bottom: 32px; }
    .add-form input  { flex: 1; padding: 8px; font-size: 14px; }
    .auth-form       { display: grid; gap: 16px; max-width: 360px; }
    .auth-form label { display: grid; gap: 6px; font-weight: 600; }
    .auth-form input { padding: 8px; font-size: 14px; }
    .auth-switch     { margin-top: 20px; }
    button           { padding: 8px 12px; cursor: pointer; }
    .todo-item       { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
    .todo-item span  { min-width: 120px; }
    .completed       { text-decoration: line-through; color: #999; }
    .error           { color: #b42318; margin-bottom: 16px; }
  </style>
</head>
<body>
  {{#if currentUser}}
    <div class="page-header">
      <div class="session-meta">
        <p>Signed in as {{currentUser.email}}</p>
      </div>
      <form action="/logout" method="POST">
        <button type="submit">Logout</button>
      </form>
    </div>
  {{/if}}
  {{{body}}}
</body>
</html>
